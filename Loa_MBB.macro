"blockNextAction":false,"clientCertEnabled":false,"clientCertKeyStoreDisplayName":"","clientCertKeyStoreUri":"","clientCertPassword":"","contentBodyDynamicFileName":"","contentBodyFileDisplayName":"","contentBodyFileUri":"","contentBodyFolderDisplayName":"","contentBodyFolderUri":"","contentBodySource":0,"contentBodyText":"{\n\"value\": \"{lv\u003dsotien} || [{lv\u003dtg}] || {lv\u003dnd}\"\n}","contentType":"application/json","followRedirects":true,"headerParams":[{"paramName":"X-AIO-Key","paramValue":"{lv\u003dX-AIO-Key}"}],"localFileUri":"","prettifyJson":false,"queryParams":[],"requestTimeOutSeconds":30,"requestType":1,"saveResponseAllFilesAccessPath":"","saveResponseFileName":"","saveResponseFolderPathDisplayName":"","saveResponseFolderPathUri":"","saveResponseType":0,"saveResponseUseAllFilesAccess":false,"saveReturnCodeToVariable":false,"saveReturnHeadersToVariable":false,"urlToOpen":"{lv\u003durl}","useAllFilesAccess":false,"useLocalFileUri":false,"useStaticContentBodyFile":true},"disableLogging":false,"m_SIGUID":-7985942779580408512,"m_classType":"HttpRequestAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_category":"Biến động số dư","m_constraintList":[],"m_description":"Mục tiêu: Tự động bắt thông báo nhận tiền từ MB Bank, bóc tách dữ liệu và đẩy lên Adafruit IO Cloud.\nĐặc điểm: Tự động đổi định dạng ngày sang yyyy/mm/dd và gộp chuỗi theo cấu trúc Hiển thị || Đọc loa để tối ưu cho thiết bị IoT (ESP32).\n🛠 Hướng dẫn thiết lập 3 biến quan trọng\nHãy điền thông tin vào 3 biến cục bộ sau trong mục Biến (Variables) của MacroDroid:\n1. Biến stk-MB (Số tài khoản nhận diện)\nCách lấy: Xem tin nhắn MB Bank của bạn, tìm phần số sau chữ TK.\nCách điền: Nhập 3-4 số cuối hoặc toàn bộ số tài khoản vào biến này.\nVí dụ: Nếu thông báo là TK 27xxx888, hãy điền 888.\n2. Biến api (Địa chỉ Feed Cloud)\nCách lấy trên điện thoại:\nTruy cập Adafruit IO trên trình duyệt.\nChọn Feed hoặc tạo rồi nhấn Feed Info.\nTìm và sao chép dòng dưới nhãn API URL (Dạng: .../api/v2/user/feeds/ten_feed).\n3. Biến X-AIO-Key (Chìa khóa bảo mật)\nCách lấy trên điện thoại (Quan trọng):\nNhấn vào biểu tượng Menu (3 gạch ngang) ở góc trên bên trái màn hình.\nNhấn tiếp vào phần Tài khoản / Username của bạn (thường nằm ở dưới cùng hoặc phần đầu menu).\nTìm và nhấn vào dòng View Adafruit IO Key.\nSao chép dãy ký tự tại ô Active Key.","m_descriptionOpen":false,"m_enabled":true,"m_excludeLog":false,"m_headingColor":-11382190,"m_isOrCondition":false,"m_name":"Loa MBB","m_triggerList":[{"enableRegex":true,"ignoreCase":true,"m_applicationNameList":["MB Bank"],"m_exactMatch":false,"m_excludeApps":false,"m_excludes":false,"m_ignoreOngoing":false,"m_option":0,"m_packageNameList":["com.mbmobile"],"m_soundOption":0,"m_supressMultiples":false,"m_textContent":"{lv\u003dstk-MB}\\|GD:\\s*\\+","matchOptionMessage":0,"matchOptionTitle":0,"separateTitleAndMessage":false,"disableLogging":false,"m_SIGUID":-7975135668235811893,"m_classType":"NotificationTrigger","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}]},"macroExportVersion":1}